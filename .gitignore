.DS_Store
Thumbs.db

# Logs / temp artifacts
*.log
_tmp_*.log
terminal_output_*.txt
naive_*.txt

# Env files (keep examples if any)
docker/.env
.env
.env.*

# Node / frontend build artifacts
node_modules/
**/node_modules/
browser-extension/dist/
webui/dist/
admin-webui/dist/

# Release bundles (scripts/release)
scripts/release/release.env
dist/release/
# Accidental `> nul` in PowerShell creates a file named NUL (reserved on Windows)
**/nul
**/NUL
# Local docker save artifacts (release bundles use dist/release/)
docker/*.tar

# IDE (local)
.vscode/

# Python virtual envs / caches (repo-root convenience)
.venv/
venv/
cli/dist/
*.egg-info/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

