{
  "manifest_version": 3,
  "name": "Voice transcriber",
  "version": "0.1.0",
  "description": "Запись звука из браузера и потоковая отправка на сервер расшифровки.",
  "permissions": [
    "tabs",
    "storage",
    "tabCapture",
    "identity",
    "activeTab",
    "contextMenus",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Voice transcriber"
  },
  "icons": {}
}

