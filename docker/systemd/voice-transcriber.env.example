# Example environment overrides for systemd units (VM deployment).
# Copy to: /etc/voice-transcriber/voice-transcriber.env
#
# Note: docker-compose.yml already sets many defaults; this is only for overrides.

# --- Security / auth ---
# VT_JWT_SECRET=your-long-random-secret
# VT_HF_TOKEN=hf_xxx  # Обязателен для pyannote diarization (gated models на HuggingFace)

# --- Публичные URL (runtime сервиса api при ``docker compose up``; не только build-args образов) ---
# Без VT_ADMIN_WEBUI_ORIGIN кнопки Google/Яндекс в админке вернут JSON 400:
#   Admin OAuth requires VT_ADMIN_WEBUI_ORIGIN(S) and a matching next URL
# При сборке дистрибутива те же значения попадают в deploy/docker/public-urls.env — скопируйте сюда.
# VT_PUBLIC_API_URL=https://voicer.example.com
# VT_WEBUI_ORIGIN=https://voicer.example.com
# Allowlist возврата после OAuth (path опционален; сравнивается origin, напр. https://voicer.example.com/admin):
# VT_ADMIN_WEBUI_ORIGIN=https://voicer.example.com/admin
# VT_CORS_ORIGINS=https://voicer.example.com,https://voicer.example.com/admin

# --- S3 / MinIO (api, worker, admin-api, diarization-worker) ---
# MinIO в том же compose:  VT_S3_ENDPOINT=http://minio:9000  (+ minioadmin по умолчанию)
# MinIO на хосте Linux:   VT_S3_ENDPOINT=http://host.docker.internal:9000
#   (порт — как слушает MinIO на ВМ; в compose у api/worker есть host.docker.internal:host-gateway)
#   НЕ используйте http://localhost:9000 из контейнера — это не хост (api упадёт на старте).
#   MinIO на хосте должен слушать 0.0.0.0 (или нужный интерфейс), не только 127.0.0.1.
# Облачный S3:           VT_S3_ENDPOINT=https://storage.yandexcloud.net
# VT_S3_BUCKET=voice-transcriber
# VT_S3_ACCESS_KEY=...
# VT_S3_SECRET_KEY=...
# VT_S3_BUCKET=my-voice-transcriber
# VT_S3_ACCESS_KEY=...
# VT_S3_SECRET_KEY=...
# Региональные endpoint AWS/Yandex — полный URL, как в документации провайдера.

# --- Optional network/publish ports (if host ports conflict) ---
# POSTGRES_PUBLISH_PORT=5435
# REDIS_PUBLISH_PORT=6382
# MINIO_PUBLISH_PORT=9012
# MINIO_CONSOLE_PUBLISH_PORT=9013

# --- ASR tuning overrides (optional) ---
# VT_ASR_MODEL=medium
# VT_ASR_DEVICE=cpu
# Разные провайдеры для realtime (API) и final (Celery) — см. configs/asr.yaml
# (по умолчанию: whisper / gigaam). Переопределение:
# VT_ASR_REALTIME_PROVIDER=whisper
# VT_ASR_FINAL_PROVIDER=gigaam
# VT_ASR_FINAL_MODEL=v3_e2e_rnnt

# --- GPU final ASR + diarization ---
# Режим split (по умолчанию): два контейнера — profile gpu
# VT_GPU_DEPLOY_MODE=split
# VT_COMPOSE_PROFILES=gpu,scale_llm
#
# Режим unified: один контейнер worker-gpu-unified — profile gpu-unified
# VT_GPU_DEPLOY_MODE=unified
# VT_COMPOSE_PROFILES=gpu-unified,scale_llm
# VT_GPU_UNIFIED_CONCURRENCY=2
# VT_GPU_UNIFIED_WORKER_QUEUES=asr_fast,asr_final,diarization
#
# VT_ASR_DEVICE=cuda
# VT_ASR_COMPUTE_TYPE=float16
# VT_DIARIZATION_DEVICE=cuda
# Уберите asr_fast у основного worker — слайсы §17 обрабатывает GPU-воркер:
# VT_MAIN_WORKER_QUEUES=asr,cleanup

# --- Celery: отдельный worker-llm (compose profile scale_llm) ---
# Если поднят сервис worker-llm, у основного worker уберите llm из очередей (docker/README.md):
# VT_MAIN_WORKER_QUEUES=asr_fast,asr,cleanup

# --- Diarization (pyannote): cpu | cuda | auto (auto пробует CUDA, при ошибке — CPU в коде) ---
# Без рабочего NVIDIA Container Toolkit задайте cpu и используйте diarization-worker (не gpu).
# VT_DIARIZATION_DEVICE=cpu

# --- Rolling LLM summary (Ollama или vLLM / OpenAI-compatible); Celery worker-llm ---
# Ollama на хосте:
# VT_OLLAMA_BASE_URL=http://host.docker.internal:11434
# VT_OLLAMA_MODEL=llama3
# vLLM (Qwen и др.) — OpenAI API /v1/chat/completions:
# VT_LLM_DEFAULT_PROVIDER=vllm
# VT_VLLM_BASE_URL=http://172.17.0.1:8000/v1
# VT_VLLM_MODEL=Qwen/Qwen3-14B-AWQ
# VT_VLLM_API_KEY=EMPTY

