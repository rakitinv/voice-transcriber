# Example environment overrides for systemd units (VM deployment).
# Copy to: /etc/voice-transcriber/voice-transcriber.env
#
# Note: docker-compose.yml already sets many defaults; this is only for overrides.

# --- Security / auth ---
# VT_JWT_SECRET=your-long-random-secret
# VT_HF_TOKEN=hf_xxx  # Only needed for online model downloads (pyannote)

# --- Optional network/publish ports (if host ports conflict) ---
# POSTGRES_PUBLISH_PORT=5435
# REDIS_PUBLISH_PORT=6382
# MINIO_PUBLISH_PORT=9012
# MINIO_CONSOLE_PUBLISH_PORT=9013

# --- ASR tuning overrides (optional) ---
# VT_ASR_MODEL=medium
# VT_ASR_DEVICE=cpu

# --- Rolling LLM summary (Ollama); Celery must reach the HTTP API ---
# Docker Desktop (Ollama on host): VT_OLLAMA_BASE_URL=http://host.docker.internal:11434
# VT_OLLAMA_MODEL=llama3

