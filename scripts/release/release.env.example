# Скопируйте в release.env рядом с этими скриптами и задайте значения.
# release.env не коммитьте (секреты и пути площадки).

# --- Версия и каталог дистрибутива (сборочная машина) ---
# Тег релиза: совпадает с VERSION / git tag (напр. v0.2.0).
VT_RELEASE_TAG=v0.2.0

# Куда положить готовый дистрибутив (build-all). Относительный путь — от корня репозитория.
VT_RELEASE_DIR=dist/release

# --- Сборка Docker-образов (build-docker) ---
# При обрывах PyPI: PIP_INDEX_URL=https://pypi.org/simple (или зеркало площадки)
# PIP_INDEX_URL=https://pypi.org/simple
# Доп. сервисы compose (только сборка на ПК; на сервере в release.env можно не задавать).
# Значение с пробелами ОБЯЗАТЕЛЬНО в кавычках — иначе install-or-update.sh падает при source.
# Доп. образы после базового docker compose build (только перечисленные сервисы, не весь стек).
# VT_DOCKER_EXTRA_SERVICES="worker-llm"
# Профили: собираются только сервисы профиля (gpu → worker-final-gpu, diarization-worker-gpu).
# Не используйте «docker compose --profile gpu build» без имён — скрипт делает это за вас.
# VT_DOCKER_COMPOSE_PROFILES=gpu

# Сохранять в дистрибутив образы postgres/redis/minio (для площадки без registry)
VT_EXPORT_INFRA_IMAGES=1

# Build-args фронтов (prod URL до docker compose build webui / admin-webui).
# Достаточно задать VT_PUBLIC_API_URL + VT_WEBUI_ORIGIN (+ VT_ADMIN_* для админки);
# VITE_* можно задать явно и переопределить compose-дефолты.
# VT_PUBLIC_API_URL=https://voicer.example.com
# VT_WEBUI_ORIGIN=https://voicer.example.com
# VT_ADMIN_WEBUI_ORIGIN=https://voicer.example.com/admin
# VITE_API_BASE_URL=https://voicer.example.com
# VITE_ADMIN_API_BASE_URL=https://voicer.example.com
# VITE_PUBLIC_API_BASE_URL=https://voicer.example.com
# VITE_ADMIN_WEBUI_SELF_URL=https://voicer.example.com/admin
# VITE_ADMIN_WEBUI_BASE_PATH=/admin/

# Расширение браузера (build-extension): Server URL по умолчанию для новых установок.
# Если не задано — build-extension подставит VT_PUBLIC_API_URL.
# VITE_DEFAULT_SERVER_URL=https://voicer.example.com

# --- Установка на сервере (install-or-update.sh) ---
# Куда синхронизировать дистрибутив (rsync в install-or-update). Если каталога ещё нет —
# запустите: bash install-or-update.sh /path/to/распакованный-дистрибутив
# (без аргумента скрипт берёт родителя scripts/release/, если есть deploy/docker).
VT_INSTALL_ROOT=/opt/voice-transcriber

# Файл переопределений для compose (секреты, внешняя БД/S3)
VT_SERVER_ENV_FILE=/etc/voice-transcriber/voice-transcriber.env

# Профили compose при up (через запятую), например gpu,diarization,scale_llm
# VT_COMPOSE_PROFILES=gpu,diarization,scale_llm
# При gpu задайте на сервере VT_MAIN_WORKER_QUEUES=asr,cleanup (см. docker/README.md → Final ASR GPU)

# Публиковать образы в registry вместо tar (опционально, build-push-registry.sh)
# VT_REGISTRY=registry.example.com/voice-transcriber
# VT_REGISTRY_TAG=2026.05.20
